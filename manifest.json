{
  "name": "Tiny web tools",
  "description": "car crash",
  "version": "1.0.0",
  "manifest_version": 3,
  "permissions": [
    "scripting",
    "activeTab",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "run-code": {
      "suggested_key": {
        "default": "Alt+Shift+1"
      },
      "description": "Opens toys menu"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["inj.js"],
      "run_at": "document_start"
    }
  ],
  


  "icons": {
    "128": "icon.png"
  }
}
